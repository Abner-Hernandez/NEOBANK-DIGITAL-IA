# === Alura Agente — Variables de Entorno ===
# Copia este archivo como ".env" y completa tus valores reales.
# NUNCA subas el archivo ".env" real a Git.

# --- Google Gemini API ---
# Obtén tu key en https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu_api_key_aqui

# --- Modelos (permite cambiarlos sin tocar código) ---
# gemini-2.5-flash: buen equilibrio calidad/free-tier (10 RPM, 250 RPD).
# Alternativa con más throughput pero menor calidad: gemini-2.5-flash-lite (15 RPM, 1000 RPD)
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Rutas de datos (relativas al root del proyecto) ---
RAW_DATA_DIR=Documentacion
VECTORSTORE_DIR=vectorstore/faiss_index

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Entorno de ejecución ---
# local | production (permite comportamientos distintos, ej. logs a stdout en prod)
APP_ENV=local

# --- CORS ---
# Orígenes permitidos separados por comas. En producción, usa el dominio real
# de tu app web en vez de "*", ej: https://miapp.com,https://staging.miapp.com
ALLOWED_ORIGINS=*
